{
  "projectRoot": ".",
  "startupSource": "double-click",
  "backend": {
    "healthPath": "/health",
    "cleanupResidualsPath": "/v1/audio/inference/cleanup-residuals",
    "cleanupTimeoutMs": 2000
  },
  "frontend": {
    "devServerPort": 5175,
    "dev": {
      "command": "npm run dev",
      "workingDirectory": "frontend"
    },
    "product": {
      "distDir": "frontend/dist",
      "staticServerHost": "127.0.0.1",
      "staticServerPort": 15175
    },
    "electron": {
      "command": "",
      "workingDirectory": "",
      "args": []
    }
  },
  "supervisor": {
    "frontendRestartDelaySeconds": 3,
    "frontendCrashWindowSeconds": 60,
    "frontendMaxCrashCount": 3,
    "backendHealthPollIntervalMs": 1000
  }
}
