{
  "name": "desktop",
  "version": "0.0.1",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "test": "vitest run tests",
    "build": "tsc -p tsconfig.json",
    "package:builder": "electron-builder --config electron-builder.yml --win dir",
    "package:portable": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\assemble-portable.ps1",
    "package:verify": "npm run test && uv run pytest ../backend/tests/unit/test_packaged_runtime_settings.py -v",
    "package": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\build-integrated-package.ps1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
