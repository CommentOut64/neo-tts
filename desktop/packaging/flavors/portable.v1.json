{
  "schemaVersion": 1,
  "flavorId": "portable.v1",
  "distributionKind": "portable",
  "builderTargets": [
    "dir",
    "zip"
  ],
  "resourcesRoot": "resources/app-runtime",
  "portableMarker": "portable.flag",
  "runtimeLayout": {
    "stateRoot": "state",
    "packagesRoot": "packages"
  },
  "userDataPolicy": {
    "userDataRoot": "./data",
    "configRoot": "./data/config",
    "ttsRegistryRoot": "./data/tts-registry",
    "cacheRoot": "./data/cache",
    "exportsRoot": "./data/exports",
    "logsRoot": "./data/logs"
  }
}
